# SQLite database (development)
DATABASE_URL=file:./data/pelak.sqlite

# Bootstrap admin (used by db:seed on first boot)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_EMAIL=admin@hokmran.com

# Optional: seed policy (auto | seed-if-empty | seed-if-no-platform-meta | never)
SEED_MODE=auto

# Session signing (required in production)
SESSION_SECRET=change-me-to-a-long-random-string

# Public site URL (sitemap/robots)
NEXT_PUBLIC_SITE_URL=https://hokmran.darkube.ir
