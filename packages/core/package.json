{
  "name": "@nextgen-cms/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*",
    "./drizzle/*": "./drizzle/*"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:backup": "tsx scripts/backup-db.ts",
    "db:migrate-media-paths": "tsx scripts/migrate-media-paths.ts",
    "db:promote-content-group-covers": "tsx scripts/promote-content-group-covers.ts",
    "db:promote-article-media": "tsx scripts/promote-article-media.ts",
    "db:promote-video-thumbnails": "tsx scripts/promote-video-thumbnails.ts",
    "db:migrate-content-group-uploads": "tsx scripts/migrate-content-group-uploads.ts"
  },
  "dependencies": {
    "@nextgen-cms/contract": "*",
    "better-sqlite3": "^12.11.1",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "jalaliday": "^3.1.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
